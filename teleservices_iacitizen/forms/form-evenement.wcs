      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">no</anonymise>
      <id type="str">25</id>
    </field>
    <field>
      <type>bool</type>
      <label type="str">Dur&#233;e ind&#233;termin&#233;e</label>
      <required type="str">optional</required>
      <varname type="str">duree_indeterminee</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">no</anonymise>
      <id type="str">26</id>
    </field>
    <field>
      <type>date</type>
      <label type="str">Date de d&#233;but</label>
      <required type="str">required</required>
      <varname type="str">date_debut</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-2-3 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <minimum_is_future type="bool">True</minimum_is_future>
      <date_in_the_past type="bool">False</date_in_the_past>
      <date_can_be_today type="bool">True</date_can_be_today>
      <id type="str">20</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Horaire d&#233;but</label>
      <condition>
        <type>django</type>
        <value>not form_var_journee_entiere</value>
      </condition>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;ex: 08:00&lt;/p&gt;</hint>
      <varname type="str">horaire_debut</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-3 pk-important</extra_css_class>
      <prefill>
        <locked>False</locked>
        <locked-unless-empty>False</locked-unless-empty>
        <type>string</type>
        <value>00:00</value>
      </prefill>
      <anonymise type="str">final</anonymise>
      <validation>
        <type>regex</type>
        <value>^([0-1][0-9]|2[0-3]):[0-5][0-9]$</value>
      </validation>
      <id type="str">22</id>
    </field>
    <field>
      <type>date</type>
      <label type="str">Date de fin</label>
      <required type="str">required</required>
      <varname type="str">date_fin</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-2-3 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <minimum_is_future type="bool">True</minimum_is_future>
      <date_in_the_past type="bool">False</date_in_the_past>
      <date_can_be_today type="bool">True</date_can_be_today>
      <id type="str">23</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Horaire fin</label>
      <condition>
        <type>django</type>
        <value>not form_var_journee_entiere and not form_var_duree_indeterminee</value>
      </condition>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;ex: 22:00&lt;/p&gt;</hint>
      <varname type="str">horaire_fin</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-3 pk-important</extra_css_class>
      <prefill>
        <locked>False</locked>
        <locked-unless-empty>False</locked-unless-empty>
        <type>string</type>
        <value>23:59</value>
      </prefill>
      <anonymise type="str">final</anonymise>
      <validation>
        <type>regex</type>
        <value>^([0-1][0-9]|2[0-3]):[0-5][0-9]$</value>
      </validation>
      <id type="str">24</id>
    </field>
