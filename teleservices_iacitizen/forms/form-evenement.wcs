      <extra_css_class type="str">newline grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">6</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Instagram</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Lien Instagram pour cet &#233;v&#233;nement&lt;/p&gt;</hint>
      <varname type="str">instagram</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">7</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">URL de l'&#233;v&#233;nement</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Veuillez saisir un lien (https://...)&lt;/p&gt;</hint>
      <varname type="str">url_event</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">30</id>
    </field>
    <field>
      <type>file</type>
      <label type="str">Image principale ( sans texte )</label>
      <required type="str">required</required>
      <hint type="str">&lt;p&gt;Les images comportant du texte ne sont pas visibles dans leur enti&#232;ret&#233; ; merci de t&#233;l&#233;verser une image sans texte.&lt;/p&gt;</hint>
      <varname type="str">image</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
        <item>listings</item>
      </display_locations>
      <extra_css_class type="str">grid-1-1 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <document_type>
        <id>_image</id>
        <label>Fichiers image</label>
        <mimetypes>image/*</mimetypes>
      </document_type>
      <allow_portfolio_picking type="bool">False</allow_portfolio_picking>
      <automatic_image_resize type="bool">False</automatic_image_resize>
      <storage type="str">default</storage>
      <id type="str">8</id>
    </field>
    <field>
      <type>bool</type>
      <label type="str">Je certifie que les images fournies respectent les droits d&#8217;auteur, qu&#8217;elles sont libres de droits ou d&#251;ment autoris&#233;es, et j&#8217;en assume l&#8217;enti&#232;re responsabilit&#233; en cas d&#8217;utilisation illicite.</label>
      <required type="str">required</required>
      <varname type="str">je_certifie_que_les_images_fournies_respectent_les_droits_d_auteur_qu_elles_sont_libres_de_droits_ou_dument_autorisees_et_j_en_assume_l_entiere_responsabilite_en_cas_d_utilisation_illicite</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">pk-important</extra_css_class>
      <anonymise type="str">no</anonymise>
      <id type="str">dc9eff1b-a7c2-4f51-9a32-11ee4e30eaae</id>
    </field>
    <field>
      <type>bool</type>
      <label type="str">Gratuit</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Cochez si l'&#233;v&#233;nement est gratuit pour tout le monde&lt;/p&gt;</hint>
      <varname type="str">gratuit</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">no</anonymise>
      <id type="str">18</id>
    </field>
    <field>
      <type>bool</type>
