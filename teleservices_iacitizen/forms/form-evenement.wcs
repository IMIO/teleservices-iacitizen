      <label type="str">X</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Lien X pour cet &#233;v&#233;nement&lt;/p&gt;</hint>
      <varname type="str">X</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
