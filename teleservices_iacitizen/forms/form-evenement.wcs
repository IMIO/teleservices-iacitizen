<?xml version="1.0"?>
<formdef id="106" url="https://rochefort-formulaires.guichet-citoyen.be/backoffice/forms/106/">
  <name>&#201;v&#233;nement</name>
  <url_name>evenement</url_name>
  <description>&lt;p&gt;&lt;strong&gt;Vous &#234;tes une association, une asbl et vous organisez un &#233;v&#232;nement&amp;nbsp;&#224; Rochefort... Vous souhaitez le diffuser dans le bulletin communal et&amp;nbsp;sur le site internet de la Ville... &amp;nbsp;Dans ce cas, n'h&#233;sitez pas... Compl&#233;tez le formulaire accessible ici afin de nous soumettre cette information, voire d'en modifier une d&#233;j&#224; r&#233;f&#233;renc&#233;e.&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Vos donn&#233;es restent sous votre enti&#232;re responsabilit&#233;. Nous d&#233;clinons toute responsabilit&#233; pour les informations erron&#233;es que vous pourriez envoyer par ce formulaire en ligne. La Ville se r&#233;serve le droit de ne pas publier ou de ne publier qu'une partie des informations transmises. L'agenda est r&#233;serv&#233; aux annonces non commerciales pour des manifestations se d&#233;roulant sur la commune de Rochefort.&lt;/p&gt;</description>
  <submission_user_association>any</submission_user_association>
  <history_pane_default_mode>expanded</history_pane_default_mode>
  <discussion>false</discussion>
  <detailed_emails>true</detailed_emails>
  <disabled>false</disabled>
  <only_allow_one>false</only_allow_one>
  <enable_tracking_codes>false</enable_tracking_codes>
  <confirmation>true</confirmation>
  <always_advertise>true</always_advertise>
  <has_captcha>false</has_captcha>
  <skip_from_360_view>false</skip_from_360_view>
  <category slug="publications" category_id="31">Publications</category>
  <workflow slug="contributions" workflow_id="50">iA.Citizen - Publications (actualit&#233;s, &#233;v&#233;nements, fiches annuaires)</workflow>
  <fields>
    <field>
      <type>page</type>
      <label type="str">Soumettre un &#233;v&#233;nement</label>
      <post_conditions>
        <post_condition>
          <condition>
            <type>django</type>
            <value>form_var_date_debut|add:" "|add:form_var_horaire_debut|datetime &lt;= form_var_date_fin|add:" "|add:form_var_horaire_fin|datetime or not form_var_horaire_debut and not form_var_horaire_fin</value>
          </condition>
          <error_message>La date de d&#233;but doit &#234;tre avant la date de fin</error_message>
        </post_condition>
      </post_conditions>
      <id type="str">46</id>
    </field>
    <field>
      <type>title</type>
      <label type="str">Soumettre un &#233;v&#233;nement</label>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <id type="str">52</id>
    </field>
    <field>
      <type>item</type>
      <label type="str">Type d'&#233;v&#233;nement</label>
      <required type="str">required</required>
      <hint type="str">&lt;p&gt;S&#233;lectionnez&lt;/p&gt;</hint>
      <varname type="str">type_event</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">pk-important</extra_css_class>
      <anonymise type="str">no</anonymise>
      <display_mode type="str">list</display_mode>
      <data_source>
        <type>json</type>
        <value>{{ passerelle_url }}plone-restapi/evenements/get_field_choices?id=imio.events.vocabulary.EventTypes</value>
      </data_source>
      <in_filters type="bool">False</in_filters>
      <display_disabled_items type="bool">False</display_disabled_items>
      <initial_zoom type="str">13</initial_zoom>
      <use_hint_as_first_option type="bool">True</use_hint_as_first_option>
      <image_desktop_size type="str">150</image_desktop_size>
      <image_mobile_size type="str">75</image_mobile_size>
      <radio_orientation type="str">auto</radio_orientation>
      <id type="str">44</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Titre</label>
      <required type="str">required</required>
      <varname type="str">titre</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-1 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <id type="str">1</id>
    </field>
    <field>
      <type>text</type>
      <label type="str">Description courte</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;R&#233;sum&#233; de l'&#233;v&#233;nement en quelques phrases maximum.&lt;/p&gt;</hint>
      <varname type="str">description</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-1 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <display_mode type="str">plain</display_mode>
      <maxlength type="str">700</maxlength>
      <id type="str">2</id>
    </field>
    <field>
      <type>text</type>
      <label type="str">Texte de pr&#233;sentation</label>
      <required type="str">optional</required>
      <varname type="str">texte</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-1 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <display_mode type="str">plain</display_mode>
      <id type="str">51</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Lien pour la participation en ligne</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Lien pour participer en ligne&lt;/p&gt;</hint>
      <varname type="str">participation</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">4</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Billeterie</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Lien de la billeterie pour s'inscrire &#224; cet &#233;v&#233;nement&lt;/p&gt;</hint>
      <varname type="str">billeterie</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">3</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Vid&#233;o</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Lien vers une vid&#233;o Youtube ou Vimeo&lt;/p&gt;</hint>
      <varname type="str">video</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">17</id>
    </field>
    <field>
      <type>string</type>
      <label type="str">Facebook</label>
      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Lien Facebook pour cet &#233;v&#233;nement&lt;/p&gt;</hint>
      <varname type="str">facebook</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">final</anonymise>
      <validation>
        <error_message>Veuillez saisir une URL (https://...)</error_message>
        <type>regex</type>
        <value>http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&amp;+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+</value>
      </validation>
      <id type="str">5</id>
    </field>
    <field>
