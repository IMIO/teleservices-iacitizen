      <required type="str">optional</required>
      <hint type="str">&lt;p&gt;Cochez si l'&#233;v&#233;nement est accessible aux personnes &#224; mobilit&#233; r&#233;duite&lt;/p&gt;</hint>
      <varname type="str">accessible</varname>
      <display_locations>
        <item>validation</item>
        <item>summary</item>
      </display_locations>
      <extra_css_class type="str">grid-1-2 pk-important</extra_css_class>
      <anonymise type="str">no</anonymise>
      <id type="str">19</id>
    </field>
    <field>
      <type>bool</type>
